{
  "mcpServers": {
    "github-grep": {
      "type": "http",
      "url": "https://mcp.grep.app"
    },
    "deepwiki": {
      "type": "http",
      "url": "https://mcp.deepwiki.com/mcp"
    },
    "gitnexus": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "gitnexus",
        "mcp"
      ],
      "env": {}
    },
    "mercury-market-data": {
      "type": "http",
      "url": "https://mcp.mercuryintelligence.net/markets/mcp",
      "headers": {
        "X-API-Key": "${MERCURY_API_KEY}"
      }
    },
    "mercury-darth-feedor": {
      "type": "http",
      "url": "https://mcp.mercuryintelligence.net/feeder/mcp",
      "headers": {
        "X-API-Key": "${MERCURY_API_KEY}"
      }
    },
    "mercury-econ-data": {
      "type": "http",
      "url": "https://mcp.mercuryintelligence.net/econ/mcp",
      "headers": {
        "X-API-Key": "${MERCURY_API_KEY}"
      }
    },
    "mercury-pubfinance": {
      "type": "http",
      "url": "https://mcp.mercuryintelligence.net/pubfinance/mcp",
      "headers": {
        "X-API-Key": "${MERCURY_API_KEY}"
      }
    }
  }
}
